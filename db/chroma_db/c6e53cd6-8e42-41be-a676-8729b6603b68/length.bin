{"version":"1.0","page":"6","source":"official_uiic_terms.pdf","section":"Coverage & Exclusions","title":"UIIC Official Health Policy Guidelines","timestamp":"2026-07-17","url":"https://uiic.co.in/web/downloadforms/downloads","category":"Policy PDF","chroma:document":"6. Cashless claims require pre-authorization: 72 hours before elective hospitalization or within 24 hours of emergency admission."}